<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.hermes.gateway-monitor</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/Users/mac/.hermes/hermes-agent/venv/bin/python3</string>
        <string>/Users/mac/.hermes/scripts/gateway-health-check.py</string>
    </array>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StartInterval</key>
    <integer>300</integer>
    
    <key>StandardOutPath</key>
    <string>/Users/mac/.hermes/logs/gateway-monitor-stdout.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/mac/.hermes/logs/gateway-monitor-stderr.log</string>
    
    <key>KeepAlive</key>
    <false/>
</dict>
</plist>
