<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.openclaw.server-watchdog</string>
    
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/mac/.openclaw/scripts/server-watchdog.sh</string>
    </array>
    
    <key>StartInterval</key>
    <integer>120</integer>
    
    <key>RunAtLoad</key>
    <true/>
    
    <key>StandardOutPath</key>
    <string>/Users/mac/.openclaw/logs/server-watchdog-out.log</string>
    
    <key>StandardErrorPath</key>
    <string>/Users/mac/.openclaw/logs/server-watchdog-err.log</string>
    
    <key>WorkingDirectory</key>
    <string>/Users/mac/.openclaw</string>
</dict>
</plist>
